model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username     String?  @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(USER)
  isBlocked    Boolean  @default(false) @map("is_blocked")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  projects          Project[]                @relation("ProjectOwner")
  memberships       ProjectMember[]          @relation("ProjectMemberUser")
  invitedMembers    ProjectMember[]          @relation("ProjectMemberInvitedBy")
  createdWorkflows  Workflow[]               @relation("WorkflowCreator")
  workflowShares    WorkflowShare[]          @relation("WorkflowShareCreatedBy")
  startedExecutions WorkflowExecution[]      @relation("ExecutionStartedBy")
  deletionAudits    ExecutionDeletionAudit[] @relation("ExecutionDeletionAuditDeletedBy")

  // Admin relations
  adminAuditLogs       AdminAuditLog[]    @relation("AdminAuditLogAdmin")
  systemSettingsUpdates SystemSettings[]  @relation("SystemSettingsUpdatedBy")
  activityLogs         UserActivityLog[]  @relation("UserActivityLogUser")

  profile UserProfile?

  @@map("users")
}

model UserProfile {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  bio       String?
  phone     String?
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("user_profiles")
}

enum Role {
  USER
  SUPER_ADMIN
}
