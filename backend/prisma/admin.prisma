// Admin Panel Models

model AdminAuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminId    String   @map("admin_id") @db.Uuid
  action     String   @db.VarChar(100) // "USER_DELETE", "ROLE_CHANGE", "PROJECT_DELETE", etc.
  targetType String   @map("target_type") @db.VarChar(50) // "USER", "PROJECT", "WORKFLOW", etc.
  targetId   String?  @map("target_id") @db.Uuid
  details    Json?    // Additional information about the action
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  admin User @relation("AdminAuditLogAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([targetType])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

model SystemSettings {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String   @unique @db.VarChar(100)
  value       Json
  description String?  @db.VarChar(500)
  updatedBy   String?  @map("updated_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  updatedByUser User? @relation("SystemSettingsUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@index([key])
  @@index([updatedAt])
  @@map("system_settings")
}

model UserActivityLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  action    String   @db.VarChar(100) // "LOGIN", "LOGOUT", "CREATE_PROJECT", "CREATE_WORKFLOW", etc.
  details   Json?    // Additional information
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation("UserActivityLogUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("user_activity_logs")
}
