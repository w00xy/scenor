DATABASE_URL="postgresql://user:password@db:5432/base_name"
PORT=3000
JWT_ACCESS_SECRET="your-strong-access-secret"
JWT_REFRESH_SECRET="your-strong-refresh-secret"
JWT_ACCESS_EXPIRES_IN="30m"
JWT_REFRESH_EXPIRES_IN="7d"

# Credentials encryption key (must be 64 hex characters = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

POSTGRES_DB=base_name
POSTGRES_IP=db  # For docker-compsoe db pulling postgres and using db for connecting
POSTGRES_USER=user
POSTGRES_PASSWORD=password